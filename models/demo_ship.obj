# Simple low-poly demo mesh for DotK wireframe renderer
# You can replace this file with any OBJ that uses v/f records.

o -demo-ship

v 0.0 0.0 1.8
v 0.9 0.0 0.5
v -0.9 0.0 0.5
v 0.0 0.45 0.2
v 0.0 -0.45 0.2
v 0.65 0.0 -0.8
v -0.65 0.0 -0.8
v 0.0 0.28 -1.1
v 0.0 -0.28 -1.1

f 1 2 4
f 1 4 3
f 1 3 5
f 1 5 2

f 2 6 8 4
f 3 4 8 7
f 3 7 9 5
f 2 5 9 6

f 6 7 8
f 6 9 7

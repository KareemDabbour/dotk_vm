{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Dot-K Interpreted Language",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#ctrl-statements"
		},
		{
			"include": "#class"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#expression"
		},
		{
			"include": "#template-strings"
		},
		{
			"include": "#prefixed-strings"
		},
		{
			"include": "#variables"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#rawStrings"
		}
	],
	"repository": {
		"ctrl-statements": {
			"patterns": [
				{
					"name": "keyword.control",
					"match": "\\b(if|else|return|yield|while|break|continue|for|in|switch|case|default|try|catch|import|from|as|module|export|var|const|fn|class|this|super|_get_|_set_|_size_|_hash_|_iter_|_next_|__iter__|__next__|toStr|_lt_|_gt_|_eq_|init)\\b"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"match": "(-?[0-9][0-9\\.]*)",
					"name": "constant.numeric.dotk"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"match": "(_*[a-zA-Z]+\\w*)",
					"name": "variable.name.dotk"
				}
			]
		},
		"class": {
			"patterns": [
				{
					"name": "entity.name.class",
					"match": "([A-Z]+\\w*)"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "support.constant",
					"match": "\\b(true|false|null|nil|bool|int|str|list|float)\\b"
				},
				{
					"name": "keyword.operator.word.dotk",
					"match": "\\b(and|or)\\b"
				}
			]
		},
		"expression": {
			"patterns": [
				{
					"include": "#keywords"
				},
				{
					"include": "#numbers"
				},
				{
					"include": "#paren-expression"
				},
				{
					"include": "#template-strings"
				},
				{
					"include": "#strings"
				},
				{
					"include": "#rawStrings"
				}
			]
		},
		"paren-expression": {
			"patterns": [
				{
					"match": "\\b(\\w+)(?:\\s+([-a-zA-Z0-9_]+))?\\s*(\\()",
					"captures": {
						"1": {
							"name": "support.function.dotk"
						},
						"0": {
							"name": "punctuation.definition.parameters.dotk"
						}
					},
					"patterns": [
						{
							"include": "#expression"
						}
					]
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"begin": "\\~",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.comment.k"
						}
					},
					"end": "\\~",
					"name": "comment.block.dotk"
				},
				{
					"captures": {
						"0": {
							"name": "punctuation.definition.comment.k"
						}
					},
					"match": "\\~\\~",
					"name": "comment.block.empty.k"
				},
				{
					"include": "#comments-inline"
				}
			]
		},
		"comments-inline": {
			"patterns": [
				{
					"begin": "#",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.comment.k"
						}
					},
					"end": "\\n",
					"name": "comment.inline.dotk"
				},
				{
					"captures": {
						"0": {
							"name": "punctuation.definition.comment.k"
						}
					},
					"match": "\\#\\n",
					"name": "comment.inline.empty.k"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.dotk",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.dotk",
					"match": "\\\\."
				}
			]
		},
		"prefixed-strings": {
			"name": "string.quoted.double.dotk",
			"begin": "(?:b|x|bin)\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.dotk",
					"match": "\\\\."
				}
			]
		},
		"rawStrings": {
			"name": "string.quoted.double.dotk",
			"begin": "`",
			"end": "`",
			"patterns": [
				{
					"name": "constant.character.escape.dotk",
					"match": "\\\\."
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"match": "!=|==|<=|>=|<|>|=>",
					"name": "keyword.operator.comparison.dotk"
				},
				{
					"match": "&&|\\|\\||!|&|\\|",
					"name": "keyword.operator.logical.dotk"
				},
				{
					"match": "\\+=|-=|\\*=|/=|//=|=|::|\\?",
					"name": "keyword.operator.assignment.dotk"
				},
				{
					"match": "<<|>>|\\*\\*|\\+|-|//|/|\\*|%|\\^|@",
					"name": "keyword.operator.dotk"
				}
			]
		},
		"template-strings": {
			"name": "string.quoted.double",
			"begin": "(f)(\")",
			"beginCaptures": {
				"1": {
					"name": "keyword.other.dotk"
				},
				"0": {
					"name": "string.quoted.double"
				}
			},
			"end": "\"",
			"endCaptures": {
				"0": {
					"name": "string.quoted.double"
				}
			},
			"patterns": [
				{
					"name": "constant.character.escape.dotk",
					"match": "\\\\."
				},
				{
					"begin": "({)",
					"beginCaptures": {
						"1": {
							"name": "punctuation.definition.template-expression.begin.dotk"
						}
					},
					"end": "(})",
					"endCaptures": {
						"1": {
							"name": "punctuation.definition.template-expression.end.dotk"
						}
					},
					"patterns": [
						{
							"include": "$self"
						}
					]
				}
			]
		}
	},
	"scopeName": "source.k"
}